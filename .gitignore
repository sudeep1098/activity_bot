# ============================================================
#   Activity Bot - .gitignore
# ============================================================

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ─────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/

# ── Environment / secrets ───────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.der

# ── Logs ───────────────────────────────────────────────────
*.log
logs/

# ── macOS system files ─────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
.fseventsd

# ── IDEs ───────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# Antigravity
.antigravity/

# JetBrains
.idea/
*.iml

# ── Misc ───────────────────────────────────────────────────
*.swp
*.swo
*~
Thumbs.db